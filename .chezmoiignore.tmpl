{{- $profile := coalesce (env "CHEZMOI_AI_PROFILE") (index .chezmoi.config.data "ai_profile") -}}
{{- if not (or (eq $profile "work") (eq $profile "personal")) -}}
{{- fail "Set data.ai_profile to \"work\" or \"personal\" in ~/.config/chezmoi/chezmoi.toml before applying this repo." -}}
{{- end -}}
# .chezmoiignore - Files and directories that chezmoi should not manage

# Documentation and scripts
README.md
scripts/

# Backup files
*.bak
*.swp
*~

# macOS specific
.DS_Store
.AppleDouble
.LSOverride

# Version control
.git/
.gitignore

# IDE and editor files
.vscode/
.idea/
*.code-workspace

# pi-mono: secrets, runtime state, and installed package trees
# (managed pi config is authored in dot_pi/; these are regenerated locally)
.pi/agent/auth.json
.pi/agent/sessions/
.pi/agent/logs/
.pi/agent/npm/
.pi/agent/git/

{{- if eq $profile "personal" }}
Library/Application Support/espanso/match/base.yml
{{- end }}
{{- if eq $profile "work" }}
Library/Application Support/espanso/match/personal-email.yml
Library/LaunchAgents/com.tfinklea.bytesaddle-weekly-replay.plist
{{- end }}

{{- range $artifact := .scopedArtifacts }}
{{- $enabled := or (eq $artifact.scope "shared") (and (eq $artifact.scope "work-only") (eq $profile "work")) (and (eq $artifact.scope "personal-only") (eq $profile "personal")) -}}
{{- if not $enabled }}
{{ printf ".%s/" (trimPrefix "dot_" $artifact.path) }}
{{- end }}
{{- end }}

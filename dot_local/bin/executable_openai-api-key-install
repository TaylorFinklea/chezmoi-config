#!/bin/sh

set -eu

if [ ! -t 0 ]; then
    echo "Run this script in a terminal so it can read the API key securely." >&2
    exit 1
fi

restore_tty() {
    stty echo
}

trap restore_tty EXIT INT TERM HUP

printf "OpenAI API key: " >&2
stty -echo
IFS= read -r openai_api_key
stty echo
trap - EXIT INT TERM HUP
printf "\n" >&2

if [ -z "$openai_api_key" ]; then
    echo "No key provided." >&2
    exit 1
fi

/usr/bin/security add-generic-password -U -a "$USER" -s OPENAI_API_KEY -w "$openai_api_key"
/bin/launchctl setenv OPENAI_API_KEY "$openai_api_key"

echo "Saved OPENAI_API_KEY to the macOS Keychain and current user launchd environment."

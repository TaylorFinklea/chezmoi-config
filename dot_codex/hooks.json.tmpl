{{- $profile := coalesce (env "CHEZMOI_AI_PROFILE") (index .chezmoi.config.data "ai_profile") -}}
{{- if not (or (eq $profile "work") (eq $profile "personal")) -}}
{{- fail "Set data.ai_profile to \"work\" or \"personal\" in ~/.config/chezmoi/chezmoi.toml, or export CHEZMOI_AI_PROFILE for one-off renders." -}}
{{- end -}}
{{- if eq $profile "work" -}}
{
  "hooks": {}
}
{{- else -}}
{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx --silent moshi-hooks --source codex",
            "timeout": 45
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx --silent moshi-hooks --source codex",
            "timeout": 45
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx --silent moshi-hooks --source codex",
            "timeout": 45
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx --silent moshi-hooks --source codex",
            "timeout": 45
          }
        ]
      }
    ]
  }
}
{{- end -}}

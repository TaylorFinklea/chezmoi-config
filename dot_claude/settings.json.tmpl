{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "LS",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npm run *)",
      "Bash(python *)",
      "WebFetch",
      "WebSearch",
      "TodoWrite"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Edit(**/*.p8)",
      "Edit(**/*.p12)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.cer)",
      "Write(**/*.p8)",
      "Write(**/*.p12)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.cer)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(docker *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx moshi-hooks # moshi-hooks",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx moshi-hooks # moshi-hooks",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx moshi-hooks # moshi-hooks",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx moshi-hooks # moshi-hooks",
            "async": true
          },
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty",
            "async": true
          }
        ],
        "matcher": "permission_prompt|idle_prompt"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx moshi-hooks # moshi-hooks",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bunx moshi-hooks # moshi-hooks",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "terraform@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": false
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    },
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "{{ .chezmoi.homeDir }}/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "allow_remote_sessions": true,
  "agentPushNotifEnabled": true
}

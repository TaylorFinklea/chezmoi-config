{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "LS",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(npm run *)",
      "Bash(python *)",
      "WebFetch",
      "WebSearch",
      "TodoWrite"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Edit(**/*.p8)",
      "Edit(**/*.p12)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.cer)",
      "Write(**/*.p8)",
      "Write(**/*.p12)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.cer)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(docker *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/moshi-hook claude-hook",
            "async": false,
            "timeout": 300
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/moshi-hook claude-hook",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run --directory {{ .chezmoi.homeDir }}/git/bytesaddle python {{ .chezmoi.homeDir }}/git/bytesaddle/harness/capture/hooks/session_start.py",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/handoff-freshness.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/uv run --directory {{ .chezmoi.homeDir }}/git/bytesaddle python {{ .chezmoi.homeDir }}/git/bytesaddle/harness/capture/hooks/session_end.py",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/moshi-hook claude-hook",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.claude/hooks/handoff-rewake.sh",
            "asyncRewake": true,
            "timeout": 10,
            "rewakeSummary": "AI handoff drift detected"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/moshi-hook claude-hook",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/jq -nc '{terminalSequence: \"\\u0007\"}'"
          }
        ],
        "matcher": "permission_prompt|idle_prompt"
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "terraform@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "vercel-plugin@vercel-vercel-plugin": false
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    },
    "vercel-vercel-plugin": {
      "source": {
        "source": "directory",
        "path": "{{ .chezmoi.homeDir }}/.cache/plugins/github.com-vercel-vercel-plugin"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "allow_remote_sessions": true,
  "agentPushNotifEnabled": true
}

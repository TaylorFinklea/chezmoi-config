{
  "mcpServers": [
    {
      "id": "microsoft-learn",
      "scope": "personal-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "http",
        "url": "https://learn.microsoft.com/api/mcp"
      }
    },
    {
      "id": "playwright",
      "scope": "shared",
      "targets": [
        "codex",
        "opencode"
      ],
      "codex": {
        "command": "npx",
        "args": [
          "@playwright/mcp@latest"
        ],
        "toolApprovals": {
          "browser_navigate": "approve",
          "browser_click": "approve"
        }
      },
      "opencode": {
        "type": "local",
        "command": [
          "npx",
          "@playwright/mcp@latest"
        ],
        "enabled": true
      }
    },
    {
      "id": "chrome-devtools",
      "scope": "shared",
      "targets": [
        "codex",
        "opencode"
      ],
      "codex": {
        "command": "npx",
        "args": [
          "chrome-devtools-mcp@latest"
        ]
      },
      "opencode": {
        "type": "local",
        "command": [
          "npx",
          "chrome-devtools-mcp@latest"
        ],
        "enabled": true
      }
    },
    {
      "id": "figma",
      "scope": "shared",
      "targets": [
        "codex",
        "opencode"
      ],
      "codex": {
        "url": "https://mcp.figma.com/mcp"
      },
      "opencode": {
        "type": "remote",
        "url": "https://mcp.figma.com/mcp",
        "enabled": true
      }
    },
    {
      "id": "shadcn",
      "scope": "shared",
      "targets": [
        "codex"
      ],
      "codex": {
        "command": "npx",
        "args": [
          "shadcn@latest",
          "mcp"
        ]
      }
    },
    {
      "id": "excalidraw",
      "scope": "shared",
      "targets": [
        "codex",
        "opencode"
      ],
      "codex": {
        "url": "https://mcp.excalidraw.com"
      },
      "opencode": {
        "type": "remote",
        "url": "https://mcp.excalidraw.com",
        "enabled": true
      }
    },
    {
      "id": "github",
      "scope": "shared",
      "targets": [
        "codex"
      ],
      "codex": {
        "url": "https://api.githubcopilot.com/mcp/",
        "bearer_token_env_var": "GITHUB_PAT_TOKEN"
      }
    },
    {
      "id": "cloudflare-docs",
      "scope": "shared",
      "targets": [
        "codex"
      ],
      "codex": {
        "url": "https://docs.mcp.cloudflare.com/mcp"
      }
    },
    {
      "id": "cloudflare-bindings",
      "scope": "shared",
      "targets": [
        "codex"
      ],
      "codex": {
        "url": "https://bindings.mcp.cloudflare.com/mcp"
      }
    },
    {
      "id": "cloudflare-builds",
      "scope": "shared",
      "targets": [
        "codex"
      ],
      "codex": {
        "url": "https://builds.mcp.cloudflare.com/mcp"
      }
    },
    {
      "id": "cloudflare-observability",
      "scope": "shared",
      "targets": [
        "codex"
      ],
      "codex": {
        "url": "https://observability.mcp.cloudflare.com/mcp"
      }
    },
    {
      "id": "atlassian_rovo",
      "scope": "work-only",
      "targets": [
        "codex",
        "copilot",
        "opencode"
      ],
      "codex": {
        "enabled": true,
        "url": "https://mcp.atlassian.com/v1/mcp"
      },
      "copilot": {
        "type": "http",
        "url": "https://mcp.atlassian.com/v1/mcp"
      },
      "opencode": {
        "type": "remote",
        "url": "https://mcp.atlassian.com/v1/mcp",
        "enabled": true
      }
    },
    {
      "id": "github-mcp-work",
      "scope": "work-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "http",
        "url": "https://api.githubcopilot.com/mcp/"
      }
    },
    {
      "id": "microsoft-learn-work",
      "scope": "work-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "http",
        "url": "https://learn.microsoft.com/api/mcp"
      }
    },
    {
      "id": "figma-work",
      "scope": "work-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "http",
        "url": "https://mcp.figma.com/mcp"
      }
    },
    {
      "id": "chrome-devtools-work",
      "scope": "work-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "stdio",
        "command": "npx",
        "args": [
          "chrome-devtools-mcp@0.12.1"
        ]
      }
    },
    {
      "id": "playwright-work",
      "scope": "work-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "stdio",
        "command": "npx",
        "args": [
          "@playwright/mcp@0.0.54"
        ]
      }
    },
    {
      "id": "terraform-work",
      "scope": "work-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "stdio",
        "command": "docker",
        "args": [
          "run",
          "-i",
          "--rm",
          "-e",
          "TFE_ADDRESS",
          "-e",
          "TFE_TOKEN",
          "-e",
          "ENABLE_TF_OPERATIONS",
          "hashicorp/terraform-mcp-server:0.4.0"
        ]
      }
    },
    {
      "id": "datadog-work",
      "scope": "work-only",
      "targets": [
        "copilot"
      ],
      "copilot": {
        "type": "http",
        "url": "https://mcp.us3.datadoghq.com/api/unstable/mcp-server/mcp"
      }
    },
    {
      "id": "simmersmith",
      "scope": "personal-only",
      "targets": [
        "codex"
      ],
      "codex": {
        "command": "/Users/tfinklea/git/simmersmith/.venv/bin/python",
        "args": [
          "/Users/tfinklea/git/simmersmith/scripts/run_simmersmith_mcp.py"
        ],
        "toolApprovals": {
          "health": "approve",
          "recipes_list": "approve",
          "profile_get": "approve",
          "preferences_get": "approve",
          "weeks_get_current": "approve",
          "weeks_get_by_start": "approve",
          "weeks_create": "approve",
          "preferences_score_meal": "approve",
          "weeks_update_meals": "approve",
          "weeks_regenerate_grocery": "approve",
          "assistant_create_thread": "approve",
          "assistant_respond": "approve",
          "assistant_get_thread": "approve",
          "assistant_list_threads": "approve"
        }
      }
    }
  ],

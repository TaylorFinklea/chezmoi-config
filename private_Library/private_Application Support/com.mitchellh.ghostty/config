theme = tokyonight
font-family = "FiraCode Nerd Font"
macos-option-as-alt = true

# Send tmux window navigation on Cmd+h/l so Alt+h/l stays free for AeroSpace.
keybind = cmd+h=esc:h
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=esc:l

# Create splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

keybind = global:cmd+backquote=toggle_quick_terminal

# Shift+Enter sends ESC+CR so Copilot CLI and Codex treat it as newline
keybind = shift+enter=text:\x1b\x0d

# Notifications from claude and codex
desktop-notifications = true
bell-features = system,attention,title,border
